VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Payments (Lemon Squeezy).
# false = local dev, checkout falls back to a free insert into purchases.
# true  = checkout goes through the create-checkout Edge Function.
VITE_PAYMENTS_ENABLED=false

# Server-side only: set these as Supabase Edge Function secrets, NEVER as
# VITE_ variables (anything prefixed VITE_ is shipped to the browser).
#   supabase secrets set LEMONSQUEEZY_API_KEY=...
#   supabase secrets set LEMONSQUEEZY_STORE_ID=...
#   supabase secrets set LEMONSQUEEZY_VARIANT_ID=...
#   supabase secrets set LEMONSQUEEZY_WEBHOOK_SECRET=...
#   supabase secrets set APP_URL=https://your-domain

# Transactional email (Resend), server-side only - Edge Function secrets:
#   supabase secrets set RESEND_API_KEY=...
#   supabase secrets set EMAIL_FROM="Setty <noreply@your-domain>"
#   supabase secrets set EMAIL_HOOK_SECRET=<random string>
# Then in the SQL editor, point the database triggers at the function:
#   insert into public.app_config (key, value) values
#     ('edge_send_email_url', 'https://<project-ref>.functions.supabase.co/send-email'),
#     ('email_hook_secret', '<same value as EMAIL_HOOK_SECRET>');

# AI style check (Edge Function style-score), server-side secrets:
#   supabase secrets set EMBEDDINGS_PROVIDER=replicate   # or 'selfhosted'
#   supabase secrets set REPLICATE_API_TOKEN=...          # ~$0.0002 per scored image
#   supabase secrets set EMBEDDINGS_ENDPOINT_URL=...      # selfhosted only
# Backfill centroids: node scripts/embed-collections.mjs (needs SUPABASE_URL,
# SUPABASE_SERVICE_ROLE_KEY, REPLICATE_API_TOKEN in the environment).

# Product analytics (PostHog EU cloud). Optional: analytics is disabled
# entirely when the key is absent or the browser sends Do-Not-Track.
VITE_POSTHOG_KEY=
